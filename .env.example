APP__ENV=local
APP__DEBUG=true
APP__HOST=0.0.0.0
APP__PORT=8000
APP__SENTRY_SDN=
APP__LOG_JSON_FORMAT=false
APP__LOG_LEVEL=INFO

DB__WRITER_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
DB__READER_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app

JWT__SECRET_KEY=change-me-in-production
JWT__ALGORITHM=HS256
JWT__ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT__REFRESH_TOKEN_EXPIRE_SECONDS=172800

REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=redis123
REDIS__DB=0

PASSWORD__HASH_SECRET_KEY=change-me-password-hash-secret

# Blob storage
# 默认使用本地文件存储，适合模板初始化和本地开发
BLOB_STORAGE__STORAGE_PROVIDER=local
BLOB_STORAGE__LOCAL_BASE_PATH=./storage
BLOB_STORAGE__DEFAULT_BUCKET=blobs
BLOB_STORAGE__INTERNAL_DOWNLOAD_BASE_URL=http://localhost:8000/blob
BLOB_STORAGE__URL_EXPIRES=3600

# 切换到 minio / s3 时再启用下面这些配置
# BLOB_STORAGE__ENDPOINT=localhost:9000
# BLOB_STORAGE__ACCESS_KEY=minioadmin
# BLOB_STORAGE__SECRET_KEY=minioadmin
# BLOB_STORAGE__IS_SECURE=false
# BLOB_STORAGE__REGION=us-east-1

# Framework
FRAMEWORK__KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FRAMEWORK__KAFKA_DEFAULT_PARTITIONS=10
FRAMEWORK__KAFKA_TOPIC_PREFIX=
FRAMEWORK__KAFKA_TOPIC_STRATEGY=fine_grained
FRAMEWORK__KAFKA_AGGREGATE_TOPIC_NAME=domain-events
FRAMEWORK__KAFKA_ENV_PREFIX=

FRAMEWORK__TEMPORAL_HOST=localhost:7233
FRAMEWORK__TEMPORAL_NAMESPACE=default
FRAMEWORK__TEMPORAL_TASK_QUEUE=temporal-event-queue
FRAMEWORK__TEMPORAL_ENV_PREFIX=

FRAMEWORK__OUTBOX_BATCH_SIZE=100
FRAMEWORK__OUTBOX_PUBLISH_INTERVAL_SECONDS=10
FRAMEWORK__OUTBOX_MAX_RETRIES=3
FRAMEWORK__OUTBOX_PUBLISH_BATCH_SIZE=1000
FRAMEWORK__ENSURE_GROUP_BEFORE_PUBLISH=false

FRAMEWORK__LAUNCHER_CONSUMER_GROUP_ID=workflow-launcher
FRAMEWORK__LAUNCHER_ENABLE_CANARY_GROUP=false
FRAMEWORK__LAUNCHER_CANARY_GROUP_SUFFIX=-canary

# Optional
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60